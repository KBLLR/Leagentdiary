# LeAgentDiary active runtime environment
# Copy to .env.development or .env.production as needed.

# HTDI API base URL.
# Required runtime endpoint: GET ${VITE_HTDI_API_URL}/diary
# Optional enrichment endpoint: GET ${VITE_HTDI_API_URL}/agents
VITE_HTDI_API_URL=http://localhost:3000/api

# Polling interval for refreshing session chronology (milliseconds)
VITE_POLL_INTERVAL=30000

# Browser-side debug logging
VITE_DEBUG=false

# HTDI request timeout (milliseconds)
VITE_API_TIMEOUT=10000

# HTDI retry count for transient failures
VITE_API_MAX_RETRIES=3
